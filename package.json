{
  "name": "aserradero-app",
  "version": "2.0.10",
  "description": "Aplicación de gestión de remitos y cuentas corrientes para aserradero",
  "homepage": "./",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/ozozod/Aserrade.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev:react": "react-scripts start",
    "electron": "electron .",
    "postinstall": "electron-rebuild",
    "rebuild": "electron-rebuild",
    "prebuild": "node -e \"try { const fs = require('fs'); const path = require('path'); if (fs.existsSync('icono.ico')) { const buildDir = 'build'; if (!fs.existsSync(buildDir)) { fs.mkdirSync(buildDir, { recursive: true }); } fs.copyFileSync('icono.ico', path.join(buildDir, 'icon.ico')); } } catch(e) {}\"",
    "build": "react-scripts build && node -e \"try { const fs = require('fs'); const path = require('path'); if (fs.existsSync('icono.ico')) { fs.copyFileSync('icono.ico', path.join('build', 'icon.ico')); } } catch(e) {}\"",
    "build:electron": "electron-builder",
    "build:win": "npm run build && electron-builder --win",
    "publish:github": "npm run build && electron-builder --win -p always",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "keywords": [
    "aserradero",
    "remitos",
    "cuentas-corrientes"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "mysql2": "^3.15.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "sharp": "^0.34.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "react-scripts": "5.0.1",
    "ssh2": "^1.17.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "extends": null,
    "appId": "com.aserradero.app",
    "productName": "Aserradero App",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "autoUpdater.js",
      "database/**/*",
      "src/config/**/*",
      "config.json.example",
      "!config.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aserradero App",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": false,
      "artifactName": "Aserradero.App-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ozozod",
        "repo": "Aserrade",
        "releaseType": "release"
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
